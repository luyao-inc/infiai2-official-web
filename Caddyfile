# 可选：仅当本机独占 80/443 时使用（docker compose 需自行增加 caddy 服务）
# 当前生产服务器与 InfiAI 共用 Nginx + Certbot，见 deploy/服务器部署HTTPS.txt
#
# Caddy：自动 HTTPS（Let's Encrypt，免费证书与续期）
# 条件：域名 A 记录指向本机；安全组放行 TCP 80、443

{
	# 可选：填写邮箱便于 Let's Encrypt 到期提醒（也可通过环境变量 CADDY_EMAIL 注入）
	# email you@example.com
}

www.earningclaw.com {
	encode gzip zstd
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
	reverse_proxy web:80
}
